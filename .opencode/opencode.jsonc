{
  "$schema": "https://opencode.ai/config.json",
  "provider": {},
  "permission": {
    "task": "allow",
    "edit": "allow",
    "write": "allow",
    "bash": "allow",
    "external_directory": {
      "~/Projects/AiPlus-Native/**": "allow",
      "~/.opencode/**": "allow",
      "~/.local/share/opencode/**": "allow",
      "/tmp/**": "allow",
      "~/Projects/AiPlus-Native/**/.env": "deny",
      "~/Projects/AiPlus-Native/**/*.key": "deny",
      "~/Projects/AiPlus-Native/**/*.pem": "deny",
      "~/Projects/AiPlus-Native/**/agent-key*": "deny",
      "~/Projects/AiPlus-Native/**/secrets/**": "deny"
    }
  },
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details",
    },
    "opencode-local": {
      "path": "~/.local/share/opencode",
      "description": "Contains opencode logs and data",
    },
  },
  "mcp": {},
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
